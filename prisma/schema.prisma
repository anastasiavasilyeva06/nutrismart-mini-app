generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  telegramId       String   @unique
  firstName        String?
  lastName         String?
  username         String?
  isPremium        Boolean  @default(false)
  language         String   @default("en")

  age              Int?
  height           Int?
  weight           Int?
  activityLevel    String?
  goals            String[]
  allergies        String[]
  dietType         String?

  dislikedFoods    String[]
  preferredCuisine String[]
  budget           Int?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  foods            Food[]
  plans            MealPlan[]
  families         FamilyMember[]
  progress         Progress[]
  shoppingLists    ShoppingList[]
}

model Food {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  name            String
  imageUrl        String?
  calories        Int
  protein         Float
  carbs           Float
  fat             Float
  fiber           Float?
  sugar           Float?

  portionSize     Int
  portionCalories Int

  healthScore     Int?
  aiSuggestions   String?
  alternatives    String[]

  mealType        String
  consumedAt      DateTime @default(now())

  createdAt       DateTime @default(now())
}

model Recipe {
  id           String   @id @default(cuid())
  name         String
  description  String?
  imageUrl     String?

  calories     Int
  protein      Float
  carbs        Float
  fat          Float

  servings     Int      @default(1)
  prepTime     Int
  cookTime     Int
  difficulty   String

  ingredients  String
  instructions String
  tags         String[]

  rating       Float?
  ratingCount  Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MealPlan {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  name          String
  startDate     DateTime
  endDate       DateTime

  dailyCalories Int
  meals         String

  isActive      Boolean  @default(false)
  isGenerated   Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Family {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  members   FamilyMember[]
}

model FamilyMember {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id])

  role      String
  joinedAt  DateTime @default(now())

  @@unique([userId, familyId])
}

model Progress {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])

  date             DateTime @default(now())
  weight           Float?

  caloriesConsumed Int      @default(0)
  proteinConsumed  Float    @default(0)
  carbsConsumed    Float    @default(0)
  fatConsumed      Float    @default(0)

  caloriesGoal     Int?
  proteinGoal      Float?
  carbsGoal        Float?
  fatGoal          Float?

  @@unique([userId, date])
}

model ShoppingList {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  name        String   @default("Shopping List")
  items       String

  isGenerated Boolean  @default(false)
  totalBudget Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

